# Clipcast environment overrides. Copy to `.env` and fill in.
# All settings are optional — Clipcast runs with sensible defaults.

# ── Linear bug reports ───────────────────────────────────────────────────────
# Enables the in-app "Submit a ticket" footer link, which files issues into a
# Linear project. The link stays hidden until LINEAR_API_KEY and LINEAR_TEAM_ID
# are both set. Generate a personal key in Linear → Settings → Security & access.
LINEAR_API_KEY=
LINEAR_TEAM_ID=
LINEAR_PROJECT_ID=
