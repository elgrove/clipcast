# Copy to backend/evals/.env.evals and fill in. .env.evals is git-ignored.
#
# API keys used by the eval suite. Loaded automatically by the CLI on every
# `uv run python -m evals ...` invocation. Kept separate from backend/.env
# (which the app's pydantic-settings auto-loads and would reject these as
# unknown fields).
#
# Only fill in the keys for providers you'll actually exercise; the registry
# only checks the env var when a run references that provider.

GEMINI_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Generic OpenAI-compatible endpoints (vLLM, LM Studio, Together, Groq,
# DeepSeek-direct, ...). The base URL is required; the API key may be left
# blank for endpoints that don't authenticate.
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
