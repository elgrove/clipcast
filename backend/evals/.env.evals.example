# Copy to backend/evals/.env.evals and fill in. .env.evals is git-ignored.
#
# API keys used by the eval suite. Loaded automatically by the CLI on every
# `uv run python -m evals ...` invocation. Kept separate from backend/.env
# (which the app's pydantic-settings auto-loads and would reject these as
# unknown fields).

GEMINI_API_KEY=

# Future providers — uncomment and fill in when the registry adds support.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
