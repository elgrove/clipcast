# Copy to backend/.env and fill in. backend/.env is git-ignored.
#
# API keys used by the eval suite (and the running app). Each AI provider has
# its own variable; set the ones you need to run.

GEMINI_API_KEY=

# Future providers — uncomment and fill in when the registry adds support.
